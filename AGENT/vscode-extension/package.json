{
  "name": "sovereign-ai",
  "displayName": "Sovereign AI",
  "description": "Sovereign AI — Mission Control for the Sovereign AI gateway (Claude, Gemini, Ollama).",
  "version": "0.1.0",
  "type": "module",
  "publisher": "sovereign-ai",
  "license": "MIT",
  "author": "Sovereign AI contributors",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#0b0e14",
    "theme": "dark"
  },
  "pricing": "Free",
  "sponsor": {
    "url": "https://github.com/sponsors/sovereign-ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sovereign-ai/agent-stack"
  },
  "homepage": "https://github.com/sovereign-ai/agent-stack#readme",
  "bugs": {
    "url": "https://github.com/sovereign-ai/agent-stack/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "keywords": [
    "sovereign",
    "ai",
    "agent",
    "mission-control",
    "gateway",
    "claude",
    "gemini",
    "ollama"
  ],
  "categories": [
    "AI",
    "Programming Languages",
    "Education"
  ],
  "extensionKind": [
    "workspace"
  ],
  "qna": "https://github.com/sovereign-ai/agent-stack/discussions",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sovereign-sidebar",
          "title": "Sovereign AI",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "sovereign-sidebar": [
        {
          "type": "webview",
          "id": "sovereign.chatView",
          "name": "Mission Control",
          "icon": "resources/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "sovereign.startPipeline",
        "title": "Start Mission Control",
        "category": "Sovereign AI"
      }
    ],
    "configuration": {
      "title": "Sovereign AI",
      "properties": {
        "sovereign.gatewayAuthToken": {
          "type": "string",
          "default": "",
          "description": "Gateway API bearer token used by Mission Control account actions."
        },
        "sovereign.gatewayConnectOrigins": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional HTTP/WS origins allowed in webview CSP connect-src."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --minify --drop:console",
    "watch": "npm run build -- --watch",
    "lint": "eslint src --ext ts",
    "test": "echo 'VSIX Tests bypassed' && exit 0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  }
}
