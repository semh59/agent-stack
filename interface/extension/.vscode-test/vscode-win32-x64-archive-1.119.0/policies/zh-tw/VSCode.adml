	<resources>
		<stringTable>
			<string id="Application">Visual Studio Code</string>
			<string id="Supported_1_101">Visual Studio Code &gt;= 1.101</string>
			<string id="Supported_1_104">Visual Studio Code &gt;= 1.104</string>
			<string id="Supported_1_107">Visual Studio Code &gt;= 1.107</string>
			<string id="Supported_1_109">Visual Studio Code &gt;= 1.109</string>
			<string id="Supported_1_110">Visual Studio Code &gt;= 1.110</string>
			<string id="Supported_1_112">Visual Studio Code &gt;= 1.112</string>
			<string id="Supported_1_113">Visual Studio Code &gt;= 1.113</string>
			<string id="Supported_1_116">Visual Studio Code &gt;= 1.116</string>
			<string id="Supported_1_118">Visual Studio Code &gt;= 1.118</string>
			<string id="Supported_1_119">Visual Studio Code &gt;= 1.119</string>
			<string id="Supported_1_67">Visual Studio Code &gt;= 1.67</string>
			<string id="Supported_1_96">Visual Studio Code &gt;= 1.96</string>
			<string id="Supported_1_99">Visual Studio Code &gt;= 1.99</string>
			<string id="Category_interactiveSessionConfigurationTitle">互動式工作階段</string>
			<string id="Category_extensionsConfigurationTitle">延伸模組</string>
			<string id="Category_terminalIntegratedConfigurationTitle">整合式終端</string>
			<string id="Category_telemetryConfigurationTitle">遙測</string>
			<string id="Category_updateConfigurationTitle">更新</string>
			<string id="BrowserChatTools">BrowserChatTools</string>
			<string id="BrowserChatTools_browser_enableChatTools">啟用後，聊天代理程式可使用瀏覽器工具開啟整合瀏覽器中的頁面並與其互動。</string>
			<string id="ChatAgentAllowedNetworkDomains">ChatAgentAllowedNetworkDomains</string>
			<string id="ChatAgentAllowedNetworkDomains_chat_agent_allowedNetworkDomains">Agent 工具 (取得工具、整合瀏覽器) 網路存取允許的網域。在啟用 {0} 或 {1} 時適用。啟用 {1} 時，這也會設定終端機沙箱網路功能。支援萬用字元，例如 {2}。當允許和拒絕的清單都是空白時，即會封鎖所有網域。拒絕的網域 (請參閱 {3}) 會優先。</string>
			<string id="ChatAgentDeniedNetworkDomains">ChatAgentDeniedNetworkDomains</string>
			<string id="ChatAgentDeniedNetworkDomains_chat_agent_deniedNetworkDomains">Agent 工具 (取得工具、整合瀏覽器) 網路存取拒絕的網域。在啟用 {0} 或 {1} 時適用。啟用 {1} 時，這也會設定終端機沙箱網路功能。優先於 {2}。支援萬用字元，例如 {3}。</string>
			<string id="ChatAgentExtensionTools">ChatAgentExtensionTools</string>
			<string id="ChatAgentExtensionTools_chat_extensionToolsEnabled">啟用使用第三方延伸模組所提供的工具。</string>
			<string id="ChatAgentMode">ChatAgentMode</string>
			<string id="ChatAgentMode_chat_agent_enabled_description">啟用時，可以從聊天啟動 Agent 模式，而且可以使用 Agent 內容中具有副作用的工具。</string>
			<string id="ChatAgentNetworkFilter">ChatAgentNetworkFilter</string>
			<string id="ChatAgentNetworkFilter_chat_agent_networkFilter">啟用時，Agent 工具 (取得工具、整合瀏覽器) 的網路存取會根據 {0} 和 {1} 加以限制。啟用 {2} 時，也會將網域篩選套用至這些工具。</string>
			<string id="ChatApprovedAccountOrganizations">ChatApprovedAccountOrganizations</string>
			<string id="ChatApprovedAccountOrganizations_chat_approvedAccountOrganizations_policy_description">將此原則設定為非空清單時，會啟用核准帳戶閘道：所有 AI 功能將停用，直到使用者登入組織與此清單有交集的 GitHub 帳戶，且帳戶端原則資料已解析完成。比較時不區分大小寫。使用 '*' 作為萬用字元，以接受任何已登入的 GitHub 或 GHE 帳戶 (在組織清單未顯示的地方，用它來進行 GHE 部署)。</string>
			<string id="ChatHooks">ChatHooks</string>
			<string id="ChatHooks_chat_useHooks_description">控制是否在代理程式的工作流程期間於策略點執行聊天勾點。勾點會從 `#chat.hookFilesLocations#` 中設定的檔案載入。</string>
			<string id="ChatMCP">ChatMCP</string>
			<string id="ChatMCP_chat_mcp_access">控制對安裝的模型內容通訊協定伺服器的存取。</string>
			<string id="ChatMCP_chat_mcp_access_none">無法存取 MCP 伺服器。</string>
			<string id="ChatMCP_chat_mcp_access_registry">允許存取從登錄安裝並由 VS Code 連線的 MCP 伺服器。</string>
			<string id="ChatMCP_chat_mcp_access_any">允許存取任何已安裝的 MCP 伺服器。</string>
			<string id="ChatPluginsEnabled">ChatPluginsEnabled</string>
			<string id="ChatPluginsEnabled_chat_plugins_enabled">在聊天中啟用 Agent 外掛程式整合。</string>
			<string id="ChatToolsAutoApprove">ChatToolsAutoApprove</string>
			<string id="ChatToolsAutoApprove_autoApprove3_description">全域自動核准 (亦稱「YOLO 模式」) 會完全停用對所有工作區中所有工具的手動核准，使 Agent 得以完全自主運作。此舉極其危險，且*絕不建議採用。即使是 GitHub Codespaces 和開發人員容器這樣的容器化環境，也可能因使用者金鑰轉送到容器而遭到入侵。

此功能會停用重大安全性保護，並使攻擊者更容易入侵機器。

注意: 此設定僅控制工具核准，並不會阻止 Agent 提出問題。若要自動回答 Agent 的問題，請使用 `#chat.autoReply#` 設定。</string>
			<string id="ChatToolsEligibleForAutoApproval">ChatToolsEligibleForAutoApproval</string>
			<string id="ChatToolsEligibleForAutoApproval_chat_tools_eligibleForAutoApproval">控制哪些工具符合自動核准資格。設定為 'false' 的工具將始終顯示確認，且絕不會提供自動批准的選項。預設行為 (或將工具設定為 'true' ) 可能會讓該工具提供自動核准的選項。</string>
			<string id="Claude3PIntegration">Claude3PIntegration</string>
			<string id="Claude3PIntegration_github_copilot_chat_claudeAgent_enabled">Enable Claude Agent sessions in VS Code. Start and resume agentic coding sessions powered by Anthropic Claude Agent SDK directly in the editor. Uses your existing Copilot subscription.</string>
			<string id="CopilotNextEditSuggestions">CopilotNextEditSuggestions</string>
			<string id="CopilotNextEditSuggestions_github_copilot_nextEditSuggestions_enabled">Whether to enable next edit suggestions (NES). NES can propose a next edit based on your recent changes.</string>
			<string id="CopilotReviewAgent">CopilotReviewAgent</string>
			<string id="CopilotReviewAgent_github_copilot_chat_reviewAgent_enabled">Enables the code review agent.</string>
			<string id="CopilotReviewSelection">CopilotReviewSelection</string>
			<string id="CopilotReviewSelection_github_copilot_chat_reviewSelection_enabled">Enables code review on current selection.</string>
			<string id="CopilotSessionSync">CopilotSessionSync</string>
			<string id="CopilotSessionSync_chat_sessionSync_enabled_policy">Enable session sync to GitHub.com for cross-device Copilot session history. When disabled by organization policy, session data is kept local only.</string>
			<string id="DeprecatedEditModeHidden">DeprecatedEditModeHidden</string>
			<string id="DeprecatedEditModeHidden_chat_editMode_hidden">啟用時，會隱藏聊天模式選擇器中的編輯模式。</string>
			<string id="McpGalleryServiceUrl">McpGalleryServiceUrl</string>
			<string id="McpGalleryServiceUrl_mcp_gallery_serviceUrl">設定要連線的 MCP 圖庫服務 URL</string>
			<string id="AllowedExtensions">AllowedExtensions</string>
			<string id="AllowedExtensions_extensions_allowed_policy">指定允許使用的延伸模組清單。這可透過限制使用未經授權的延伸模組，協助保有安全且一致的開發環境。詳細資訊: https://aka.ms/vscode/enterprise/extensions/allowed</string>
			<string id="ExtensionGalleryServiceUrl">ExtensionGalleryServiceUrl</string>
			<string id="ExtensionGalleryServiceUrl_extensions_gallery_serviceUrl">設定要連線至的 Marketplace 服務 URL</string>
			<string id="ChatAgentSandboxEnabled">ChatAgentSandboxEnabled</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting">控制 Agent 模式是否使用沙箱來限制工具的功能。啟用後，終端機等工具會在沙箱環境中執行，以限制對系統的存取。</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting_offDescription">停用代理程式模式工具的沙箱功能</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting_onDescription">啟用代理程式模式工具的沙箱功能。</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting_allowNetworkDescription">Enable sandboxing for agent mode tools and allow all network domains.</string>
			<string id="ChatToolsTerminalEnableAutoApprove">ChatToolsTerminalEnableAutoApprove</string>
			<string id="ChatToolsTerminalEnableAutoApprove_autoApproveMode_description">控制是否允許在終端機工具中自動核准。</string>
			<string id="EnableFeedback">EnableFeedback</string>
			<string id="EnableFeedback_telemetry_feedback_enabled">啟用意見反應機制，例如問題回報程式、調查和其他意見反應選項。</string>
			<string id="TelemetryLevel">TelemetryLevel</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_policyDescription">控制遙測層級。</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_default">傳送使用狀況資料、錯誤和當機報告。</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_error">傳送一般錯誤遙測和當機報告。</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_crash">傳送 OS 層級當機報告。</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_off">停用所有產品遙測。</string>
			<string id="UpdateMode">UpdateMode</string>
			<string id="UpdateMode_updateMode">設定是否要接收自動更新。變更後需要重新啟動。系統會從 Microsoft 線上服務擷取更新。</string>
			<string id="UpdateMode_none">無</string>
			<string id="UpdateMode_manual">停用自動背景更新檢查。若您手動檢查更新，可取得更新。</string>
			<string id="UpdateMode_start">開始</string>
			<string id="UpdateMode_default">系統</string>
		</stringTable>
