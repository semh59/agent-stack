{
  "name": "alloy-ai",
  "displayName": "Alloy AI",
  "description": "Alloy AI — Mission Control for the Alloy AI gateway (Claude, Gemini, Ollama).",
  "version": "0.1.0",
  "publisher": "alloy-ai",
  "license": "MIT",
  "author": "Alloy AI contributors",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#0b0e14",
    "theme": "dark"
  },
  "pricing": "Free",
  "sponsor": {
    "url": "https://github.com/sponsors/alloy-ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alloy-ai/alloy-core"
  },
  "homepage": "https://github.com/alloy-ai/alloy-core#readme",
  "bugs": {
    "url": "https://github.com/alloy-ai/alloy-core/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "keywords": [
    "alloy",
    "ai",
    "agent",
    "mission-control",
    "gateway",
    "claude",
    "gemini",
    "ollama"
  ],
  "categories": [
    "AI",
    "Programming Languages",
    "Education"
  ],
  "extensionKind": [
    "workspace"
  ],
  "qna": "https://github.com/alloy-ai/alloy-core/discussions",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "alloy-sidebar",
          "title": "Alloy AI",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "alloy-sidebar": [
        {
          "type": "webview",
          "id": "alloy.chatView",
          "name": "Mission Control",
          "icon": "resources/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "alloy.startPipeline",
        "title": "Start Mission Control",
        "category": "Alloy AI"
      },
      {
        "command": "alloy.addAccount",
        "title": "Add Account",
        "category": "Alloy AI"
      },
      {
        "command": "alloy.openAccounts",
        "title": "Manage Accounts",
        "category": "Alloy AI"
      }
    ],
    "configuration": {
      "title": "Alloy AI",
      "properties": {
        "alloy.gatewayAuthToken": {
          "type": "string",
          "default": "",
          "description": "Gateway API bearer token used by Mission Control account actions."
        },
        "alloy.gatewayConnectOrigins": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional HTTP/WS origins allowed in webview CSP connect-src."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "typecheck": "tsc --noEmit",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:playwright --external:playwright-core --external:chromium-bidi --platform=node --format=cjs --minify --drop:console",
    "watch": "npm run build -- --watch",
    "lint": "eslint src --ext ts",
    "test": "npm run compile; node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^6.2.2",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "playwright-core": "^1.59.1",
    "typescript": "^5.4.5",
    "ws": "^8.20.0"
  }
}
