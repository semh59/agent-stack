# Ollama (yerel model servisi)
AI_STACK_OLLAMA_URL=http://localhost:11434
AI_STACK_OLLAMA_FAST_MODEL=qwen2.5:7b-q4_K_M
AI_STACK_OLLAMA_PROSE_MODEL=mistral:7b-q4_K_M
AI_STACK_OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenRouter (opsiyonel, ücretsiz tier)
AI_STACK_OPENROUTER_API_KEY=

# Cache
AI_STACK_SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.85

# Logging
AI_STACK_LOG_LEVEL=INFO

# Veri dizini (default: ~/.bridge)
# AI_STACK_DATA_DIR=/custom/path
