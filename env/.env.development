# ──────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT env — safe defaults for local laptop use.
# DO NOT USE IN STAGING OR PRODUCTION.
#
# Usage:
#   cp env/.env.development .env
#   npm run dev
#
# Every non-placeholder value in this file is a known-insecure default. The
# bridge and gateway will boot; auth is weak by design so you don't need a
# secrets manager to iterate.
# ──────────────────────────────────────────────────────────────────────────────

APP_ENV=development
NODE_ENV=development
LOG_LEVEL=DEBUG

# ── Gateway ─────────────────────────────────────────────────────────────────
SOVEREIGN_GATEWAY_PORT=3000
SOVEREIGN_GATEWAY_HOST=127.0.0.1
# KNOWN-INSECURE: dev token; rotated in staging/prod.
SOVEREIGN_GATEWAY_TOKEN=dev-local-token
GATEWAY_AUTH_TOKEN=dev-local-token

# ── Providers ───────────────────────────────────────────────────────────────
GOOGLE_OAUTH_ENABLED=true
CLAUDE_AUTH_ENABLED=true
CLAUDE_API_KEY=
CLAUDE_OAUTH_REDIRECT_URI=http://127.0.0.1:51121/oauth-callback

# ── Bridge ──────────────────────────────────────────────────────────────────
AI_STACK_BRIDGE_HOST=127.0.0.1
AI_STACK_BRIDGE_PORT=9100
# KNOWN-INSECURE: dev secret so you don't need Secrets Manager locally.
AI_STACK_BRIDGE_SECRET=dev-local-bridge-secret
BRIDGE_CORS_ORIGIN=http://127.0.0.1:3000

# ── Ollama ──────────────────────────────────────────────────────────────────
AI_STACK_OLLAMA_URL=http://localhost:11434
AI_STACK_OLLAMA_FAST_MODEL=gemma4:e2b
AI_STACK_OLLAMA_PROSE_MODEL=gemma4:e2b
AI_STACK_OLLAMA_EMBED_MODEL=nomic-embed-text
AI_STACK_OLLAMA_TIMEOUT=120

# ── Data ────────────────────────────────────────────────────────────────────
AI_STACK_DATA_DIR=./data
AI_STACK_OPENROUTER_API_KEY=
