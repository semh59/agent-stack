# ──────────────────────────────────────────────────────────────────────────────
# PRODUCTION env template.
#
# CRITICAL: this file is documentation. Real production values live in AWS
# Secrets Manager and are injected at ECS task start via `secrets = [...]`
# in the task definition. See terraform/modules/ecs-service.
# ──────────────────────────────────────────────────────────────────────────────

APP_ENV=production
NODE_ENV=production
LOG_LEVEL=WARNING

# ── Gateway ─────────────────────────────────────────────────────────────────
SOVEREIGN_GATEWAY_PORT=3000
SOVEREIGN_GATEWAY_HOST=0.0.0.0
SOVEREIGN_GATEWAY_TOKEN=<from-secrets-manager>
GATEWAY_AUTH_TOKEN=<from-secrets-manager>

# ── Providers ───────────────────────────────────────────────────────────────
GOOGLE_OAUTH_ENABLED=true
CLAUDE_AUTH_ENABLED=true
CLAUDE_API_KEY=<from-secrets-manager>
CLAUDE_OAUTH_CLIENT_ID=<from-secrets-manager>
CLAUDE_OAUTH_CLIENT_SECRET=<from-secrets-manager>
CLAUDE_OAUTH_REDIRECT_URI=https://sovereign.example.com/oauth-callback

# ── Bridge ──────────────────────────────────────────────────────────────────
AI_STACK_BRIDGE_HOST=optimization-bridge.prod.internal
AI_STACK_BRIDGE_PORT=9100
AI_STACK_BRIDGE_SECRET=<from-secrets-manager>
BRIDGE_CORS_ORIGIN=https://sovereign.example.com

# ── LLMs ────────────────────────────────────────────────────────────────────
# Production uses OpenRouter + managed models. Ollama is optional.
AI_STACK_OPENROUTER_API_KEY=<from-secrets-manager>
AI_STACK_OLLAMA_TIMEOUT=30    # tighter in prod — fail fast

# ── Data ────────────────────────────────────────────────────────────────────
AI_STACK_DATA_DIR=/data

# ── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.prod.internal:4318
OTEL_SERVICE_NAMESPACE=sovereign-ai
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production
