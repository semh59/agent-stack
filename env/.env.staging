# ──────────────────────────────────────────────────────────────────────────────
# STAGING env template.
#
# Values marked "<from-secrets-manager>" are injected by the deployment
# pipeline (see terraform/modules/secrets.tf — aws_secretsmanager_secret). Do
# NOT commit real values.
#
# Precedence (highest wins):
#   1. Container environment (ECS task definition)
#   2. Secrets Manager → container env at boot
#   3. This file as documentation
# ──────────────────────────────────────────────────────────────────────────────

APP_ENV=staging
NODE_ENV=production    # Node runtime uses production mode in staging too
LOG_LEVEL=INFO

# ── Gateway ─────────────────────────────────────────────────────────────────
SOVEREIGN_GATEWAY_PORT=3000
SOVEREIGN_GATEWAY_HOST=0.0.0.0
SOVEREIGN_GATEWAY_TOKEN=<from-secrets-manager>
GATEWAY_AUTH_TOKEN=<from-secrets-manager>

# ── Providers ───────────────────────────────────────────────────────────────
GOOGLE_OAUTH_ENABLED=true
CLAUDE_AUTH_ENABLED=true
CLAUDE_API_KEY=<from-secrets-manager>
CLAUDE_OAUTH_CLIENT_ID=<from-secrets-manager>
CLAUDE_OAUTH_CLIENT_SECRET=<from-secrets-manager>
CLAUDE_OAUTH_REDIRECT_URI=https://staging.sovereign.example.com/oauth-callback

# ── Bridge ──────────────────────────────────────────────────────────────────
AI_STACK_BRIDGE_HOST=optimization-bridge.staging.internal
AI_STACK_BRIDGE_PORT=9100
AI_STACK_BRIDGE_SECRET=<from-secrets-manager>
BRIDGE_CORS_ORIGIN=https://staging.sovereign.example.com

# ── Ollama / OpenRouter ─────────────────────────────────────────────────────
# In staging we usually skip local Ollama and use OpenRouter only.
AI_STACK_OLLAMA_URL=http://ollama.staging.internal:11434
AI_STACK_OLLAMA_TIMEOUT=60
AI_STACK_OPENROUTER_API_KEY=<from-secrets-manager>

# ── Data ────────────────────────────────────────────────────────────────────
# Persistent volume mounted at /data in containers.
AI_STACK_DATA_DIR=/data

# ── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.staging.internal:4318
OTEL_SERVICE_NAMESPACE=sovereign-ai
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=staging
