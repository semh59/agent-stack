# Ollama (yerel model servisi)
ALLOY_OLLAMA_URL=http://localhost:11434
ALLOY_OLLAMA_FAST_MODEL=qwen2.5:7b-q4_K_M
ALLOY_OLLAMA_PROSE_MODEL=mistral:7b-q4_K_M
ALLOY_OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenRouter (opsiyonel, ücretsiz tier)
ALLOY_OPENROUTER_API_KEY=

# Cache
ALLOY_SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.85

# Logging
ALLOY_LOG_LEVEL=INFO

# Veri dizini (default: ~/.bridge)
# ALLOY_DATA_DIR=/custom/path
