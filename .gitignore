# ────────────────────────────────────────────────────────────────────────
# Sovereign — repo ignore rules (single source of truth)
# ────────────────────────────────────────────────────────────────────────

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Dependencies
node_modules/
.venv/
venv/
ENV/
bin/
include/
lib/
share/
pyvenv.cfg
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build / dist
**/dist/
**/build/
**/out/
**/.next/
**/.docusaurus/
**/target/
*.exe
*.dll
*.so
*.dylib
*.tgz
*.tar.gz
**/*.tsbuildinfo

# Secrets / environment
/.env
/.env.*
!/.env.example
!env/.env.development
!env/.env.staging
!env/.env.production
*.pem
*.key
*.crt
*.p12

# Explicit secret fixtures (never commit these paths again)
**/temp_*.txt
**/temp_*.env
**/temp_encoded_exec.*
**/gateway_token.txt
**/token-store.json
**/.tmp/
**/.tmp_*/

# Test artifacts & rotations
**/*.db
**/*.db-journal
**/*.db.corrupt.*
**/*.sqlite
**/*.sqlite3
**/test-workspace*/
**/test-missions-*.db*
**/test-results.txt
**/final_test_report.txt
**/test-errors.log
**/test-out.txt
**/test-report.txt
**/test-file.ts
**/test_e2e_pipeline.ts
**/*.lcov
**/coverage/

# VS Code extension packages
**/*.vsix

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
antigravity-debug-*.log
tsc-errors.log
tsc-errors.txt
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json
.eslintcache

# Debug / audit / lint output (never commit)
eslint_audit*.txt
fresh_eslint_errors*.txt
fresh_tsc_errors*.txt
test_output*.txt
trace_output*.txt
tsc-detailed.txt
tsc_audit.txt
tsc_output.txt
tsc_errors*.txt
errors.txt
tmp.txt
tmp_test*.ts
tmp_test*.js

# Debug screenshots and images
*-debug.png
*-debug.jpg
screenshots-debug/
**/screenshots-debug/
accounts-debug.png

# Playwright / test artifacts
**/test-results/
playwright-report/
