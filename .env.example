# ──────────────────────────────────────────────────────────────────────────────
# Alloy AI Platform — Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Gateway (TypeScript) ─────────────────────────────────────────────────────
ALLOY_GATEWAY_PORT=51122
ALLOY_GATEWAY_TOKEN=               # Bearer token for Gateway API access
GATEWAY_AUTH_TOKEN=                    # Same as above, used by Docker Compose

# ── Provider: Google Antigravity ─────────────────────────────────────────────
GOOGLE_OAUTH_ENABLED=true

# ── Provider: Claude Code ────────────────────────────────────────────────────
CLAUDE_API_KEY=                        # Direct API key (sk-ant-xxx)
CLAUDE_AUTH_ENABLED=true
CLAUDE_OAUTH_CLIENT_ID=                # OAuth client ID (optional)
CLAUDE_OAUTH_CLIENT_SECRET=            # OAuth client secret (optional)
CLAUDE_OAUTH_REDIRECT_URI=http://localhost:51121/oauth-callback

# ── Optimization Bridge (Python) ─────────────────────────────────────────────
ALLOY_BRIDGE_HOST=127.0.0.1
ALLOY_BRIDGE_PORT=9100
ALLOY_BRIDGE_SECRET=                # Shared secret for Gateway↔Bridge auth
BRIDGE_CORS_ORIGIN=http://127.0.0.1:3000

# ── Ollama (Local LLM) ──────────────────────────────────────────────────────
ALLOY_OLLAMA_URL=http://localhost:11434
ALLOY_OLLAMA_FAST_MODEL=gemma4:e2b
ALLOY_OLLAMA_PROSE_MODEL=gemma4:e2b
ALLOY_OLLAMA_EMBED_MODEL=nomic-embed-text
ALLOY_OLLAMA_TIMEOUT=120

# ── RAG & Data ───────────────────────────────────────────────────────────────
ALLOY_DATA_DIR=./data
ALLOY_OPENROUTER_API_KEY=           # For OpenRouter fallback (optional)

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
