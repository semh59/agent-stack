{
    "name": "@alloy/gateway",
    "version": "1.4.6",
    "description": "Alloy AI — Gateway, mission orchestrator, and optimization pipeline frontend",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "license": "MIT",
    "author": "Alloy AI contributors",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alloy-ai/agent-stack.git"
    },
    "homepage": "https://github.com/alloy-ai/agent-stack#readme",
    "bugs": {
        "url": "https://github.com/alloy-ai/agent-stack/issues"
    },
    "keywords": [
        "alloy",
        "ai",
        "gateway",
        "fastify",
        "mission-orchestrator",
        "oauth",
        "mcp",
        "claude",
        "gemini",
        "ollama"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "build:schema": "npx tsx script/build-schema.ts",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --ext .ts,.tsx,.mjs",
        "lint:fix": "eslint . --ext .ts,.tsx,.mjs --fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build",
        "test:e2e:models": "npx tsx script/test-models.ts",
        "test:e2e:regression": "npx tsx script/test-regression.ts",
        "ui:dev": "npm run dev --prefix ui",
        "ui:build": "npm run build --prefix ui",
        "agent:start": "npx tsx scripts/start-agent.ts",
        "agent:auth": "npx tsx scripts/start-agent.ts --auth-only",
        "agent:add": "npx tsx scripts/add-account.ts",
        "agent:revoke": "npx tsx scripts/revoke-tokens.ts",
        "agent:rotate-keys": "npx tsx scripts/manage-keys.ts rotate-keys",
        "agent:export-keys": "npx tsx scripts/manage-keys.ts export-keys",
        "agent:import-keys": "npx tsx scripts/manage-keys.ts import-keys",
        "gateway:start": "npx tsx scripts/start-gateway.ts",
        "gateway:token:generate": "npx tsx scripts/gateway-token.ts generate",
        "gateway:token:rotate": "npx tsx scripts/gateway-token.ts rotate",
        "verify:phase3": "npx tsx scripts/verify-phase3.ts",
        "security:scan": "npx tsx scripts/secret-scan.ts"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "devDependencies": {
        "@eslint/js": "^9.15.0",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/async-lock": "^1.4.2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/chokidar": "^1.7.5",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^24.10.12",
        "@types/proper-lockfile": "^4.1.4",
        "@types/vscode": "^1.98.0",
        "@types/ws": "^8.18.1",
        "@vitest/coverage-v8": "^4.1.4",
        "@vitest/ui": "^4.1.4",
        "eslint": "^9.15.0",
        "jsdom": "^28.1.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.15.0",
        "vitest": "^4.1.4",
        "zod-to-json-schema": "^3.25.1"
    },
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "@fastify/static": "^9.0.0",
        "@fastify/websocket": "^11.2.0",
        "@openauthjs/openauth": "^0.4.3",
        "@opencode-ai/plugin": "^1.4.7",
        "@xenova/transformers": "^2.17.2",
        "async-lock": "^1.4.1",
        "better-sqlite3": "^12.9.0",
        "chokidar": "^5.0.0",
        "fastify": "^5.8.2",
        "js-yaml": "^4.1.1",
        "node-machine-id": "^1.1.12",
        "pino-pretty": "^13.1.3",
        "playwright": "^1.59.1",
        "proper-lockfile": "^4.1.2",
        "ts-morph": "^28.0.0",
        "xdg-basedir": "^5.1.0",
        "zod": "^4.3.6"
    },
    "overrides": {
        "@tootallnate/once": "^3.0.1",
        "hono": "^4.12.4",
        "minimatch": "^9.0.7",
        "rollup": "^4.59.0",
        "tar": "^7.5.10"
    }
}
